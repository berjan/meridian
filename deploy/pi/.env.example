# Copy to .env and edit. .env is git-ignored.
#
# Local mode (Pi and Meridian on the same machine) — leave both unset/empty.
#
# Shared LAN mode (one Meridian server, multiple Pi clients) — uncomment both:
#
#   MERIDIAN_BIND_HOST=0.0.0.0
#   MERIDIAN_API_KEY=replace-me-with-a-long-random-secret
#
# Generate a strong key with: openssl rand -hex 32

MERIDIAN_BIND_HOST=
MERIDIAN_API_KEY=
